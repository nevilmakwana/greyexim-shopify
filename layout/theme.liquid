<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% # theme-check-disable RemoteAsset %}
    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {{ 'custom-koraa.css' | asset_url | stylesheet_tag }}
    {{ 'mobile-koraa.css' | asset_url | stylesheet_tag }}
    <style>
      :root {
        --custom-announcement-padding-desktop: {{ settings.announcement_padding_desktop | default: 10 }}px;
        --custom-announcement-padding-mobile: {{ settings.announcement_padding_mobile | default: 8 }}px;
        --custom-header-padding-desktop: {{ settings.header_padding_desktop | default: 6 }}px;
        --custom-header-padding-mobile: {{ settings.header_padding_mobile | default: 6 }}px;
      }
      {% if template.name == 'index' %}
      /* FOUC prevention: immediately hide announcement + header bg on index page load */
      body:not(.koraa-scroll-ready) #koraa-announcement {
        opacity: 0 !important;
        max-height: 0 !important;
        padding-top: 0 !important;
        padding-bottom: 0 !important;
        overflow: hidden !important;
        transition: none !important;
      }
      body:not(.koraa-scroll-ready) .header__underlay-closed,
      body:not(.koraa-scroll-ready) .header__underlay-open {
        opacity: 0 !important;
        transition: none !important;
      }
      body:not(.koraa-scroll-ready) .header {
        background: transparent !important;
        transition: none !important;
      }
      body:not(.koraa-scroll-ready) .header__row--top {
        border-bottom-color: transparent !important;
      }

      /* Fix header group to overlay hero from first paint */
      #header-group {
        display: block !important;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 999;
        width: 100%;
      }

      /* Once JS loads, it enables transitions */
      body.koraa-scroll-ready #koraa-announcement {
        transition: opacity 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                    transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                    max-height 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) !important;
      }
      body.koraa-scroll-ready .header__underlay-closed,
      body.koraa-scroll-ready .header__underlay-open {
        transition: opacity 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) !important;
      }
      body.koraa-scroll-ready .header {
        transition: background 0.35s ease !important;
      }
      body.koraa-scroll-ready .header__row--top {
        transition: border-bottom-color 0.35s ease !important;
      }
      /* Temporarily hide common cookie consent banners */
      #shopify-pc__banner, 
      .cc-window, 
      .cc-banner, 
      .cookie-banner, 
      #cookie-banner, 
      .gdpr-cookie-message, 
      #gdpr-cookie-message, 
      .shopify-privacy-banner, 
      .pc-bannerContainer,
      .cookie-consent,
      #cookie-consent {
        display: none !important;
        opacity: 0 !important;
        visibility: hidden !important;
        pointer-events: none !important;
      }
      {% endif %}
    </style>
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    {% # theme-check-enable RemoteAsset %}
  </head>

  <body class="template-{{ template.name | handle }} page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}" {% if template.name == 'index' %}data-koraa-scroll-state="hidden"{% endif %}>
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    
    {% if template.name == 'product' %}
      {% render 'mobile-product-header' %}
    {% endif %}

    <div id="header-group">
      {%- render 'koraa-announcement-bar' -%}
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height and menu style calculations to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerTopRow = header.querySelector('.header__row--top');
        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        if (headerTopRow) {
          window.requestAnimationFrame(function () {
            document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
          });
        }

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        }
      })();
    </script>

    {% comment %} Koraa Scroll State Controller — Immersive Hero + Header Reveal {% endcomment %}
    {% if template.name == 'index' %}
    <script>
      (function() {
        var body = document.body;
        var currentState = 'hidden'; // Start hidden on index
        var heroObserver = null;
        var heroElement = null;

        function setState(newState) {
          if (newState === currentState) return;
          currentState = newState;
          body.setAttribute('data-koraa-scroll-state', newState);

          // Recalculate header height after state change
          requestAnimationFrame(function() {
            var header = document.querySelector('header-component');
            if (header) {
              body.style.setProperty('--header-height', header.offsetHeight + 'px');
            }
          });
        }

        function initHeroObserver() {
          // Find the hero carousel section
          heroElement = document.getElementById('koraa-carousel');
          if (!heroElement) {
            // Fallback: look for the first section in main content
            heroElement = document.querySelector('#MainContent > .shopify-section:first-child');
          }
          if (!heroElement) return;

          // Use IntersectionObserver to track when hero leaves viewport
          // threshold: 0.15 means when less than 15% of hero is visible, trigger
          heroObserver = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting && entry.intersectionRatio > 0.15) {
                // Hero is significantly visible — keep header transparent
                setState('hidden');
              } else {
                // Hero scrolled out of view — show header with bg
                setState('visible');
              }
            });
          }, {
            threshold: [0, 0.15, 0.5],
            rootMargin: '0px 0px 0px 0px'
          });

          heroObserver.observe(heroElement);

          // Enable CSS transitions after initial state is set
          requestAnimationFrame(function() {
            body.classList.add('koraa-scroll-ready');
          });
        }

        // Initialize when DOM is ready
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initHeroObserver);
        } else {
          initHeroObserver();
        }

        // Fallback: if hero hasn't loaded yet, try again after load
        window.addEventListener('load', function() {
          if (!heroElement) initHeroObserver();
        });
      })();
    </script>
    {% endif %}

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% render 'koraa-footer' %}
    <footer class="koraa-desktop-footer-only">
      {% sections 'footer-group' %}
    </footer>
    <style>
      @media screen and (max-width: 749px) {
        .koraa-desktop-footer-only {
          display: none !important;
        }
      }
    </style>

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}

    {% render 'mobile-bottom-nav' %}
    {% render 'koraa-search-menu' %}
    {% render 'wishlist-drawer' %}
    {% render 'account-drawer' %}

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const updateStickyHeight = () => {
          const details = document.querySelector('.product-information__grid--half .product-details');
          if (details) {
            details.style.setProperty('--elem-height', details.offsetHeight + 'px');
          }
        };
        updateStickyHeight();
        window.addEventListener('resize', updateStickyHeight);
        
        // Smoothly slide the container upwards when accordions are clicked
        document.body.addEventListener('click', (e) => {
          if (e.target.closest('summary') || e.target.closest('.accordion')) {
            let start = performance.now();
            const animate = (time) => {
               updateStickyHeight();
               if (time - start < 450) { // Keep updating slightly longer than the CSS block-size transition
                   requestAnimationFrame(animate);
               }
            };
            requestAnimationFrame(animate);
          }
        });
      });
    </script>
    
    {% render 'hm-favourites-fullscreen' %}
  </body>
</html>
