<!-- Koraa-Style Newsletter Section -->
<div class="koraa-newsletter koraa-section">
  <h3 class="koraa-newsletter__title">{{ section.settings.heading }}</h3>
  <p class="koraa-newsletter__subtitle">{{ section.settings.subheading }}</p>
  {% form 'customer', id: 'koraa-newsletter-form' %}
    <div class="koraa-newsletter__form">
      <input
        class="koraa-newsletter__input"
        type="email"
        name="contact[email]"
        placeholder="{{ section.settings.placeholder }}"
        required
        autocomplete="email"
      >
      <input type="hidden" name="contact[tags]" value="newsletter">
      <button type="submit" class="koraa-newsletter__button">
        {{ section.settings.button_label }}
      </button>
    </div>
    {% if form.posted_successfully? %}
      <p style="color: var(--koraa-accent-soft); margin-top: 12px; font-size: 0.85rem;">Thank you for subscribing!</p>
    {% endif %}
  {% endform %}
</div>

{% schema %}
{
  "name": "Koraa Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join us"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Subscribe to get 10% off your first order. No spam ever, just the good stuff."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input Placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Koraa Newsletter"
    }
  ]
}
{% endschema %}
