<!-- Koraa Instagram Grid Section -->
<section class="koraa-instagram koraa-section">
  {% if section.settings.heading != blank or section.settings.subheading != blank %}
    <div class="koraa-instagram__header">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="koraa-instagram__grid">
    {% for block in section.blocks %}
      {% liquid
        assign post_link = block.settings.link
        assign image_alt = block.settings.alt | default: section.settings.heading | default: 'Instagram post'
      %}
      {% if block.settings.image != blank %}
        {% if post_link != blank %}
          <a
            href="{{ post_link }}"
            class="koraa-instagram__item"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="{{ image_alt | escape }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.image | image_url: width: 900 | image_tag: widths: '300, 450, 600, 900', sizes: '(max-width: 749px) 50vw, 16vw', loading: 'lazy', class: 'koraa-instagram__image', alt: image_alt }}
            <span class="koraa-instagram__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <rect x="3" y="3" width="18" height="18" rx="5"></rect>
                <circle cx="12" cy="12" r="4"></circle>
                <circle cx="17.5" cy="6.5" r="1.2"></circle>
              </svg>
            </span>
          </a>
        {% else %}
          <div class="koraa-instagram__item" {{ block.shopify_attributes }}>
            {{ block.settings.image | image_url: width: 900 | image_tag: widths: '300, 450, 600, 900', sizes: '(max-width: 749px) 50vw, 16vw', loading: 'lazy', class: 'koraa-instagram__image', alt: image_alt }}
          </div>
        {% endif %}
      {% else %}
        <div class="koraa-instagram__item koraa-instagram__item--placeholder" {{ block.shopify_attributes }}>
          {{ 'image' | placeholder_svg_tag: 'koraa-instagram__placeholder' }}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Koraa Instagram Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Follow us on Instagram"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "@greyexim"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Instagram photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Instagram post link"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Koraa Instagram Grid",
      "blocks": [
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}
