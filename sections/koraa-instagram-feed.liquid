<!-- Koraa Instagram Feed — Live via Instafeed.js -->
<section
  class="koraa-insta-feed koraa-section"
  id="koraa-insta-feed-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-token="{{ section.settings.access_token | escape }}"
  data-count="{{ section.settings.post_count }}"
  data-columns="{{ section.settings.columns_desktop }}"
  data-handle="{{ section.settings.instagram_handle | escape }}"
>

  {%- if section.settings.heading != blank or section.settings.instagram_handle != blank -%}
    <div class="koraa-insta-feed__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="koraa-insta-feed__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.instagram_handle != blank -%}
        <a
          class="koraa-insta-feed__handle"
          href="https://www.instagram.com/{{ section.settings.instagram_handle | remove: '@' }}/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Visit {{ section.settings.instagram_handle }} on Instagram"
        >
          <svg class="koraa-insta-feed__handle-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="1.7"/>
            <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.7"/>
            <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/>
          </svg>
          @{{ section.settings.instagram_handle | remove: '@' }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  <!-- Live feed grid populated by Instafeed.js -->
  <div
    class="koraa-insta-feed__grid"
    id="koraa-instafeed-{{ section.id }}"
    aria-label="Instagram feed for @{{ section.settings.instagram_handle | remove: '@' }}"
  ></div>

  <!-- Loading skeleton shown while feed loads -->
  <div class="koraa-insta-feed__skeleton" id="koraa-insta-skeleton-{{ section.id }}" aria-hidden="true">
    {%- for i in (1..12) -%}
      <div class="koraa-insta-feed__skeleton-item">
        <div class="koraa-insta-feed__skeleton-shimmer"></div>
      </div>
    {%- endfor -%}
  </div>

  <!-- Error / not-configured state -->
  <div class="koraa-insta-feed__notice" id="koraa-insta-notice-{{ section.id }}" style="display:none;" aria-live="polite">
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="1.5"/>
      <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.5"/>
      <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor"/>
    </svg>
    <p id="koraa-insta-notice-msg-{{ section.id }}">Add your Instagram Access Token in the theme customizer to display live posts.</p>
    {%- if section.settings.instagram_handle != blank -%}
      <a
        href="https://www.instagram.com/{{ section.settings.instagram_handle | remove: '@' }}/"
        target="_blank"
        rel="noopener noreferrer"
        class="koraa-insta-feed__notice-link"
      >
        Follow us on Instagram →
      </a>
    {%- endif -%}
  </div>

</section>

<!-- Instafeed.js — always loaded so it can show the notice/skeleton in editor too -->
<script src="{{ 'koraa-instafeed.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Koraa Instagram Feed",
  "settings": [
    {
      "type": "paragraph",
      "content": "⚡ Live Instagram feed powered by Instafeed.js. Requires an Instagram Basic Display API access token."
    },
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Follow us on Instagram"
    },
    {
      "type": "text",
      "id": "instagram_handle",
      "label": "Instagram handle (e.g. greyexim)",
      "default": "greyexim"
    },
    {
      "type": "range",
      "id": "post_count",
      "label": "Number of posts to show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 12
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        { "value": "4", "label": "4 columns" },
        { "value": "5", "label": "5 columns" },
        { "value": "6", "label": "6 columns" }
      ],
      "default": "6"
    },
    {
      "type": "header",
      "content": "Instagram API"
    },
    {
      "type": "paragraph",
      "content": "Paste your long-lived Instagram Basic Display API access token below. See the setup guide for step-by-step instructions on generating one."
    },
    {
      "type": "text",
      "id": "access_token",
      "label": "Instagram Access Token",
      "placeholder": "IGQ..."
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Koraa Instagram Feed"
    }
  ]
}
{% endschema %}
