<!-- Koraa-Style Product Carousel Section with Premium Slide-In -->
{% assign dummy_images = "https://images.unsplash.com/photo-1594938298603-c8148c4dae35?w=600&q=80&auto=format,https://images.unsplash.com/photo-1583743814966-8936f5b7be1a?w=600&q=80&auto=format,https://images.unsplash.com/photo-1562157873-818bc0726f68?w=600&q=80&auto=format,https://images.unsplash.com/photo-1551488831-00ddcb6c6bd3?w=600&q=80&auto=format,https://images.unsplash.com/photo-1596755094514-f87e34085b2c?w=600&q=80&auto=format" | split: "," %}
{% assign dummy_titles = "Chunky Windowpane Crop Top,Quilted Crop Top,Cecily Vest - Denim,Spencer Barrel Pant,Adrian Wrap Pant" | split: "," %}
{% assign dummy_vendors = "Ersa Fibers,Ersa Fibers,Pamut Apparel,Pamut Apparel,Pamut Apparel" | split: "," %}
{% assign dummy_prices = "$142.00,$142.00,$148.00,$238.00,$238.00" | split: "," %}

<div class="koraa-products koraa-section">
  <div class="koraa-section-header">
    <div style="display: flex; flex-direction: column; gap: 8px;">
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.view_all_link != blank %}
        <a href="{{ section.settings.view_all_link }}">View all</a>
      {% endif %}
    </div>
    
    <div class="koraa-carousel-nav" style="display: flex; gap: 12px;">
      <button class="koraa-nav-btn koraa-nav-prev" aria-label="Previous">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="koraa-nav-btn koraa-nav-next" aria-label="Next">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>

  {%- assign my_collection = section.settings.collection -%}
  {%- if my_collection.products == blank -%}
    {%- assign my_collection = collections[section.settings.collection] -%}
  {%- endif -%}
  
  {% if my_collection != blank and my_collection.products.size > 0 %}
    <!-- Real products from collection -->
    {%- assign required_tags = section.settings.product_tag | split: ',' -%}
    {%- assign has_required_tags = false -%}
    {%- for required_tag in required_tags -%}
      {%- assign normalized_required_tag = required_tag | strip | downcase -%}
      {%- if normalized_required_tag != blank -%}
        {%- assign has_required_tags = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    <div style="display:none;" data-debug="Collection: {{ my_collection.title }}, Products: {{ my_collection.products.size }}{% if section.settings.product_tag != blank %}, Tags: {{ section.settings.product_tag }}{% endif %}"></div>
    <div class="koraa-products__grid" id="koraa-grid-{{ section.id }}">
      {%- assign product_count = 0 -%}
      {%- for product in my_collection.products -%}
        {%- assign prod_title_check = product.title | downcase -%}
        {%- if prod_title_check contains 'custom design' -%}
          {%- continue -%}
        {%- endif -%}
        {%- if has_required_tags -%}
          {%- assign matches_required_tag = false -%}
          {%- for required_tag in required_tags -%}
            {%- assign normalized_required_tag = required_tag | strip | downcase -%}
            {%- if normalized_required_tag == blank -%}
              {%- continue -%}
            {%- endif -%}
            {%- for product_tag in product.tags -%}
              {%- assign normalized_product_tag = product_tag | strip | downcase -%}
              {%- if normalized_product_tag == normalized_required_tag -%}
                {%- assign matches_required_tag = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if matches_required_tag -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- unless matches_required_tag -%}
            {%- continue -%}
          {%- endunless -%}
        {%- endif -%}
        {%- if product_count >= section.settings.max_products -%}
          {%- break -%}
        {%- endif -%}
        {%- assign product_count = product_count | plus: 1 -%}
        <product-card class="koraa-product-card">
          <div class="koraa-product-card__image-wrapper" style="position: relative;">
            {% assign is_best_seller = false %}
            {% for tag in product.tags %}
              {% assign lower_tag = tag | strip | downcase %}
              {% if lower_tag == 'best seller' or lower_tag == 'bestseller' or lower_tag == 'best-seller' or lower_tag == 'best_seller' %}
                {% assign is_best_seller = true %}
                {% break %}
              {% endif %}
            {% endfor %}
            
            {% if is_best_seller %}
              <div class="koraa-product-card__badge-bestseller" style="position: absolute; top: 12px; left: 12px; background: #000; color: #fff; font-size: 10px; font-weight: 600; text-transform: uppercase; padding: 4px 10px; border-radius: 4px; z-index: 2; letter-spacing: 0.5px;">Best Seller</div>
            {% endif %}

            <a href="{{ product.url }}" ref="productCardLink" style="text-decoration: none; color: inherit; display: block; width: 100%; height: 100%;" class="koraa-card-link">
              {% if product.images.size > 1 %}
                <div class="koraa-swipe-carousel" data-product-id="{{ product.id }}">
                  <div class="koraa-swipe-track">
                    {% for image in product.images limit: 5 %}
                      <div class="koraa-swipe-slide">
                        <img
                          class="koraa-product-card__image"
                          src="{{ image | image_url: width: 600 }}"
                          alt="{{ image.alt | default: product.title }}"
                          loading="lazy"
                        >
                      </div>
                    {% endfor %}
                  </div>
                  <div class="koraa-swipe-dots">
                    {% for image in product.images limit: 5 %}
                      <span class="koraa-swipe-dot{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}"></span>
                    {% endfor %}
                  </div>
                </div>
              {% elsif product.featured_image %}
                <img
                  class="koraa-product-card__image"
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.title }}"
                  loading="lazy"
                >
              {% endif %}
            </a>

            <!-- Floating Action Icons (Outside the Anchor Tag to prevent navigation) -->
            <div class="product-card__action-icons" style="position: absolute; bottom: 8px; right: 8px; display: flex; flex-direction: row; gap: 6px; z-index: 9999;">
              
              <!-- Wishlist Icon -->
              <button
                type="button"
                class="custom-wishlist-trigger"
                style="display: flex; align-items: center; justify-content: center; width: 26px; height: 26px; min-width: 0 !important; min-height: 0 !important; border-radius: 50%; background: rgba(255, 255, 255, 0.95); box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12); border: none; color: #111; padding: 0; cursor: pointer;"
                data-product-id="{{ product.id }}"
                data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                data-product-url="{{ product.url }}"
                data-product-title="{{ product.title | escape }}"
                data-product-image="{{ product.featured_image | image_url: width: 200 }}"
                data-product-price="{{ product.price | money }}"
                aria-label="Add to wishlist"
                onclick="handleCustomWishlistClick(event, this)"
              >
                <svg style="width: 14px; height: 14px; stroke: currentColor; stroke-width: 1.5px; fill: none;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                </svg>
              </button>

              <!-- Cart / Quick Add Icon -->
              <button
                type="button"
                class="custom-cart-trigger"
                style="display: flex; align-items: center; justify-content: center; width: 26px; height: 26px; min-width: 0 !important; min-height: 0 !important; border-radius: 50%; background: rgba(255, 255, 255, 0.95); box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12); border: none; color: #111; padding: 0; cursor: pointer;"
                data-product-url="{{ product.url }}"
                aria-label="Quick add"
                onclick="handleCustomCartClick(event, '{{ product.url }}')"
              >
                <svg style="width: 12px; height: 12px; stroke: currentColor; stroke-width: 1.5px; fill: none;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                  <line x1="3" y1="6" x2="21" y2="6"></line>
                  <path d="M16 10a4 4 0 0 1-8 0"></path>
                </svg>
              </button>

            </div>

            <!-- Hidden quick add component -->
            <div style="display: none;" class="koraa-hidden-quick-add">
              {% render 'quick-add', product: product, section_id: section.id %}
            </div>

            <a href="{{ product.url }}" style="text-decoration: none; color: inherit; display: block; width: 100%; height: 100%;">
              <button class="koraa-product-card__quickview" type="button">Quick view</button>
            </a>
          </div>
          
          <a href="{{ product.url }}" style="text-decoration: none; color: inherit; display: block; width: 100%; height: 100%;">
            <div class="koraa-product-card__info">
              <p class="koraa-product-card__title">{{ product.title }}</p>

              {% if product.compare_at_price > product.price %}
                <p class="koraa-product-card__price">
                  <span class="koraa-product-card__price--compare">{{ product.compare_at_price | money }}</span>
                  <span class="koraa-product-card__price--sale">{{ product.price | money }}</span>
                </p>
                {% assign savings = product.compare_at_price | minus: product.price %}
                <span class="koraa-product-card__save">Save {{ savings | money }}</span>
              {% else %}
                <p class="koraa-product-card__price">{{ product.price | money }}</p>
              {% endif %}
            </div>
          </a>
        </product-card>
      {%- endfor -%}
    </div>
  {% else %}
    {%- if my_collection != blank and my_collection.products.size == 0 -%}
      <div style="text-align: center; padding: 20px; background: #ffebee; color: #c62828; margin: 0 40px 20px;">
        <strong>Notice:</strong> The collection you selected ("{{ my_collection.title }}") has 0 products. Please select a different collection or add products to it. Displaying placeholders instead.
      </div>
    {%- endif -%}
    <!-- Placeholder products for preview -->
    <div class="koraa-products__grid" id="koraa-grid-{{ section.id }}">
      {%- for i in (0..4) -%}
        <div class="koraa-product-card">
          <a href="#" style="text-decoration: none; color: inherit; display: block; width: 100%; height: 100%;">
            <div class="koraa-product-card__image-wrapper">
              <img
                class="koraa-product-card__image"
                src="{{ dummy_images[i] }}"
                alt="{{ dummy_titles[i] }}"
                loading="lazy"
              >
              <button class="koraa-product-card__quickview" type="button">Quick view</button>
            </div>
            <div class="koraa-product-card__info">
              <p class="koraa-product-card__title">{{ dummy_titles[i] }}</p>

              <p class="koraa-product-card__price">{{ dummy_prices[i] }}</p>
            </div>
          </a>
        </div>
      {%- endfor -%}
    </div>
  {% endif %}

</div>

<style>
  .koraa-nav-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--koraa-border, #E5DFD4);
    background: transparent;
    color: var(--koraa-text-dark, #1A1A1A);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .koraa-nav-btn:hover {
    background: var(--koraa-text-dark, #1A1A1A);
    color: #fff;
    border-color: var(--koraa-text-dark, #1A1A1A);
  }

  @media screen and (max-width: 749px) {
    .koraa-carousel-nav {
      display: none !important;
    }
  }

  /* Premium Right-to-Left Slide-In Animation */
  .koraa-products__grid .koraa-product-card {
    opacity: 0;
    transform: translate3d(60px, 0, 0); /* Starts slightly from the right */
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), 
                transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: opacity, transform;
  }

  /* Triggered state */
  .koraa-products__grid.is-visible .koraa-product-card {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  /* Smooth Stagger Delays using CSS instead of JS for better performance */
  .koraa-products__grid.is-visible .koraa-product-card:nth-child(1) { transition-delay: 0.00s; }
  .koraa-products__grid.is-visible .koraa-product-card:nth-child(2) { transition-delay: 0.08s; }
  .koraa-products__grid.is-visible .koraa-product-card:nth-child(3) { transition-delay: 0.16s; }
  .koraa-products__grid.is-visible .koraa-product-card:nth-child(4) { transition-delay: 0.24s; }
  .koraa-products__grid.is-visible .koraa-product-card:nth-child(5) { transition-delay: 0.32s; }
  .koraa-products__grid.is-visible .koraa-product-card:nth-child(6) { transition-delay: 0.40s; }
  .koraa-products__grid.is-visible .koraa-product-card:nth-child(7) { transition-delay: 0.48s; }
  .koraa-products__grid.is-visible .koraa-product-card:nth-child(8) { transition-delay: 0.56s; }
  .koraa-products__grid.is-visible .koraa-product-card:nth-child(9) { transition-delay: 0.64s; }
  .koraa-products__grid.is-visible .koraa-product-card:nth-child(n+10) { transition-delay: 0.72s; }

  /* Swipeable Product Image Carousel */
  .koraa-swipe-carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
    touch-action: pan-y pinch-zoom;
  }

  .koraa-swipe-track {
    display: flex;
    width: 100%;
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform;
  }

  .koraa-swipe-track.is-swiping {
    transition: none !important;
  }

  .koraa-swipe-slide {
    min-width: 100%;
    width: 100%;
    flex-shrink: 0;
  }

  .koraa-swipe-slide .koraa-product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .koraa-swipe-dots {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 5px;
    z-index: 3;
    pointer-events: none;
  }

  .koraa-swipe-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .koraa-swipe-dot.active {
    background: #fff;
    transform: scale(1.3);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sections = document.querySelectorAll('.koraa-products');
    if (!sections.length) return;

    sections.forEach(section => {
      if (section.dataset.koraaProductsInitialized === 'true') return;
      section.dataset.koraaProductsInitialized = 'true';

      const grid = section.querySelector('.koraa-products__grid');
      const prevBtn = section.querySelector('.koraa-nav-prev');
      const nextBtn = section.querySelector('.koraa-nav-next');

      // 1. Setup Intersection Observer for Slide-In Animation
      if (grid) {
        const observer = new IntersectionObserver((entries, obs) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              // Add visibility class to the grid container to trigger pure CSS animation
              entry.target.classList.add('is-visible');
              obs.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.1,
          rootMargin: "0px 0px -50px 0px"
        });

        observer.observe(grid);
      }

      // 2. Setup Premium Slider Navigation
      if (grid && prevBtn && nextBtn) {
        const getScrollAmount = () => {
          const card = grid.querySelector('.koraa-product-card');
          if (card) {
            const gap = parseInt(window.getComputedStyle(grid).gap) || 20;
            return card.offsetWidth + gap;
          }
          return 300;
        };

        nextBtn.addEventListener('click', () => {
          const scrollAmount = getScrollAmount() * 2;
          grid.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });

        prevBtn.addEventListener('click', () => {
          const scrollAmount = getScrollAmount() * 2;
          grid.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });

        const updateButtons = () => {
          const scrollLeft = grid.scrollLeft;
          const maxScroll = grid.scrollWidth - grid.clientWidth;

          prevBtn.style.opacity = scrollLeft <= 0 ? '0.3' : '1';
          prevBtn.style.cursor = scrollLeft <= 0 ? 'default' : 'pointer';

          nextBtn.style.opacity = scrollLeft >= maxScroll - 10 ? '0.3' : '1';
          nextBtn.style.cursor = scrollLeft >= maxScroll - 10 ? 'default' : 'pointer';
        };

        grid.addEventListener('scroll', updateButtons, { passive: true });
        window.addEventListener('resize', updateButtons, { passive: true });
        setTimeout(updateButtons, 100);

        // Premium drag to scroll
        let isDown = false;
        let startX;
        let scrollLeft;

        grid.addEventListener('mousedown', (e) => {
          isDown = true;
          grid.style.cursor = 'grabbing';
          grid.style.scrollBehavior = 'auto'; // Disable smooth scroll while dragging
          startX = e.pageX - grid.offsetLeft;
          scrollLeft = grid.scrollLeft;
        });

        grid.addEventListener('mouseleave', () => {
          isDown = false;
          grid.style.cursor = 'grab';
          grid.style.scrollBehavior = 'smooth';
        });

        grid.addEventListener('mouseup', () => {
          isDown = false;
          grid.style.cursor = 'grab';
          grid.style.scrollBehavior = 'smooth';
        });

        grid.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - grid.offsetLeft;
          const walk = (x - startX) * 1.5; // Drag speed multiplier
          grid.scrollLeft = scrollLeft - walk;
        });
      }

      // 3. Setup Swipeable Product Image Carousels
      const carousels = section.querySelectorAll('.koraa-swipe-carousel');
      carousels.forEach(carousel => {
        const track = carousel.querySelector('.koraa-swipe-track');
        const dots = carousel.querySelectorAll('.koraa-swipe-dot');
        const slides = carousel.querySelectorAll('.koraa-swipe-slide');
        const link = carousel.closest('.koraa-card-link');
        if (!track || slides.length < 2) return;

        let currentIndex = 0;
        let startX = 0;
        let currentX = 0;
        let isDragging = false;
        let didSwipe = false;

        const setSlide = (index) => {
          currentIndex = Math.max(0, Math.min(index, slides.length - 1));
          track.style.transform = `translateX(-${currentIndex * 100}%)`;
          dots.forEach((d, i) => d.classList.toggle('active', i === currentIndex));
        };

        // Prevent link navigation if user swiped
        if (link) {
          link.addEventListener('click', (e) => {
            if (didSwipe) {
              e.preventDefault();
              didSwipe = false;
            }
          });
        }

        carousel.addEventListener('touchstart', (e) => {
          isDragging = true;
          didSwipe = false;
          startX = e.touches[0].clientX;
          currentX = startX;
          track.classList.add('is-swiping');
        }, { passive: true });

        carousel.addEventListener('touchmove', (e) => {
          if (!isDragging) return;
          currentX = e.touches[0].clientX;
          const diff = currentX - startX;
          const offset = -(currentIndex * 100) + (diff / carousel.offsetWidth) * 100;
          track.style.transform = `translateX(${offset}%)`;
        }, { passive: true });

        carousel.addEventListener('touchend', () => {
          if (!isDragging) return;
          isDragging = false;
          track.classList.remove('is-swiping');
          const diff = currentX - startX;
          const threshold = carousel.offsetWidth * 0.2; // 20% threshold

          if (Math.abs(diff) > threshold) {
            didSwipe = true;
            if (diff < 0 && currentIndex < slides.length - 1) {
              setSlide(currentIndex + 1);
            } else if (diff > 0 && currentIndex > 0) {
              setSlide(currentIndex - 1);
            } else {
              setSlide(currentIndex); // snap back
            }
          } else {
            setSlide(currentIndex); // snap back
          }
        });
      });

    });
  });
</script>

<script>
  function koraaGetWishlist() {
    try { return JSON.parse(localStorage.getItem('greyexim_wishlist')) || []; }
    catch(e) { return []; }
  }

  function koraaSaveWishlist(list) {
    localStorage.setItem('greyexim_wishlist', JSON.stringify(list));
    // Trigger badge update globally if the function exists
    if (typeof window.updateWishlistBadge === 'function') window.updateWishlistBadge();
    if (typeof window.updateBadge === 'function') window.updateBadge(); // some themes use this
  }

  function koraaIsInWishlist(productId) {
    return koraaGetWishlist().some(item => String(item.id) === String(productId));
  }

  function handleCustomWishlistClick(e, btn) {
    e.preventDefault();
    e.stopPropagation();
    
    const productId = btn.dataset.productId;
    
    if (koraaIsInWishlist(productId)) {
      // Remove from wishlist
      const list = koraaGetWishlist().filter(item => String(item.id) !== String(productId));
      koraaSaveWishlist(list);
      
      btn.classList.remove('is-wishlisted');
      btn.querySelector('svg').style.fill = 'none';
      btn.querySelector('svg').style.stroke = '#111';
      if (typeof showToast === 'function') showToast('Removed from Wishlist');
    } else {
      // Add to wishlist
      const list = koraaGetWishlist();
      list.push({
        id: productId,
        variantId: btn.dataset.variantId,
        url: btn.dataset.productUrl,
        title: btn.dataset.productTitle,
        image: btn.dataset.productImage,
        price: btn.dataset.productPrice,
        addedAt: Date.now()
      });
      koraaSaveWishlist(list);

      btn.classList.add('is-wishlisted');
      btn.querySelector('svg').style.fill = '#e74c3c';
      btn.querySelector('svg').style.stroke = '#e74c3c';
      if (typeof showToast === 'function') showToast('Added to Wishlist ♥');
    }
  }

  function handleCustomCartClick(e, productUrl) {
    e.preventDefault();
    e.stopPropagation();
    
    // Find the quick add button and trigger it
    const card = e.target.closest('product-card');
    if (card) {
      const quickAddBtn = card.querySelector('quick-add-component .add-to-cart-button');
      if (quickAddBtn) {
        quickAddBtn.click();
        return;
      }
      
      const quickViewBtn = card.querySelector('.koraa-product-card__quickview');
      if (quickViewBtn) {
        quickViewBtn.click();
        return;
      }
    }
    
    // Fallback: navigate to product page
    window.location.href = productUrl;
  }
  
  // Set initial state on load
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.custom-wishlist-trigger').forEach(btn => {
      if (koraaIsInWishlist(btn.dataset.productId)) {
        btn.classList.add('is-wishlisted');
        btn.querySelector('svg').style.fill = '#e74c3c';
        btn.querySelector('svg').style.stroke = '#e74c3c';
      }
    });
  });
</script>

