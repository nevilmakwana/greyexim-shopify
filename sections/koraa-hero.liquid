<!-- Koraa Hero Banner — Multi-Slide Carousel with Full Controls -->
<div 
  class="koraa-carousel" 
  id="koraa-carousel"
  data-speed="{{ section.settings.slide_duration }}"
  data-effect="{{ section.settings.transition_effect }}"
  data-autoplay="{{ section.settings.autoplay }}"
>
  {%- comment -%} Dot Navigation {%- endcomment -%}
  {% if section.blocks.size > 1 %}
    <div class="koraa-carousel__dots">
      {% for block in section.blocks %}
        <button 
          class="koraa-carousel__dot {% if forloop.first %}is-active{% endif %}" 
          data-index="{{ forloop.index0 }}"
          aria-label="Slide {{ forloop.index }}"
        ></button>
      {% endfor %}
    </div>
  {% endif %}

  {%- comment -%} Slides {%- endcomment -%}
  <div class="koraa-carousel__track">
    {% for block in section.blocks %}
      {%- liquid
        assign text_color = block.settings.text_color | default: '#ffffff'
        assign overlay_opacity = block.settings.overlay_opacity | default: 30
        assign text_position = block.settings.text_position | default: 'bottom-left'
        assign heading_size = block.settings.heading_size | default: 42
        assign subtitle_size = block.settings.subtitle_size | default: 11
        assign desc_size = block.settings.desc_size | default: 14
      -%}

      <div 
        class="koraa-carousel__slide {% if forloop.first %}is-active{% endif %}" 
        {{ block.shopify_attributes }}
        style="color: {{ text_color }};"
      >
        {%- comment -%} Desktop Image & Video {%- endcomment -%}
        {% if block.settings.video_desktop != blank %}
          <div class="koraa-carousel__video-wrap koraa-carousel__image--desktop">
            {{ block.settings.video_desktop | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, class: 'koraa-carousel__video' }}
          </div>
        {% elsif block.settings.image %}
          <img 
            class="koraa-carousel__image koraa-carousel__image--desktop"
            src="{{ block.settings.image | image_url: width: 2000 }}"
            alt="{{ block.settings.heading | escape }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          >
        {% else %}
          <div class="koraa-carousel__placeholder"></div>
        {% endif %}

        {%- comment -%} Mobile Image & Video (falls back to desktop) {%- endcomment -%}
        {% if block.settings.video_mobile != blank %}
          <div class="koraa-carousel__video-wrap koraa-carousel__image--mobile">
            {{ block.settings.video_mobile | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, class: 'koraa-carousel__video' }}
          </div>
        {% elsif block.settings.video_desktop != blank %}
          <div class="koraa-carousel__video-wrap koraa-carousel__image--mobile">
            {{ block.settings.video_desktop | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, class: 'koraa-carousel__video' }}
          </div>
        {% elsif block.settings.image_mobile %}
          <img 
            class="koraa-carousel__image koraa-carousel__image--mobile"
            src="{{ block.settings.image_mobile | image_url: width: 1000 }}"
            alt="{{ block.settings.heading | escape }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          >
        {% elsif block.settings.image %}
          <img 
            class="koraa-carousel__image koraa-carousel__image--mobile"
            src="{{ block.settings.image | image_url: width: 1000 }}"
            alt="{{ block.settings.heading | escape }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          >
        {% endif %}

        {%- comment -%} Overlay — per-slide or global fallback {%- endcomment -%}
        {%- assign final_overlay = overlay_opacity | default: section.settings.global_overlay | default: 20 -%}
        <div class="koraa-carousel__overlay" style="background: rgba(0,0,0,{{ final_overlay | divided_by: 100.0 }});"></div>

        {%- comment -%} Text Content {%- endcomment -%}
        <div class="koraa-carousel__content koraa-carousel__content--{{ text_position }}">
          {% if block.settings.subtitle != blank %}
            <span class="koraa-carousel__subtitle" style="font-size: {{ subtitle_size }}px;">
              {{ block.settings.subtitle }}
            </span>
          {% endif %}

          {% if block.settings.heading != blank %}
            <h2 class="koraa-carousel__heading" style="font-size: {{ heading_size }}px;">
              {{ block.settings.heading }}
            </h2>
          {% endif %}

          {% if block.settings.description != blank %}
            <p class="koraa-carousel__desc" style="font-size: {{ desc_size }}px;">
              {{ block.settings.description }}
            </p>
          {% endif %}

          {% if block.settings.button_label != blank %}
            <a 
              href="{{ block.settings.button_link }}" 
              class="koraa-carousel__cta"
              style="
                {% if block.settings.button_style == 'outline' %}
                  background: transparent; border: 1.5px solid {{ text_color }}; color: {{ text_color }};
                {% elsif block.settings.button_style == 'solid-white' %}
                  background: #fff; border: none; color: #000;
                {% elsif block.settings.button_style == 'solid-black' %}
                  background: #000; border: none; color: #fff;
                {% else %}
                  background: transparent; border: 1.5px solid {{ text_color }}; color: {{ text_color }};
                {% endif %}
              "
            >{{ block.settings.button_label }}</a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .koraa-carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  .koraa-carousel__track {
    display: grid;
    width: 100%;
  }
  .koraa-carousel__slide {
    grid-area: 1 / 1;
    position: relative;
    width: 100%;
    opacity: 0;
    pointer-events: none;
    will-change: opacity, transform;
    z-index: 1;
  }
  .koraa-carousel__slide.is-active {
    opacity: 1;
    pointer-events: auto;
    z-index: 3;
  }
  .koraa-carousel__slide.is-exiting {
    z-index: 2;
  }

  /* Images — always cover full area, no white space */
  .koraa-carousel__slide {
    min-height: {{ section.settings.hero_height_desktop | default: 100 }}vh;
  }
  .koraa-carousel__image {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    display: block;
    object-fit: cover;
    object-position: center;
  }
  /* Video wrapper — same positioning as images */
  .koraa-carousel__video-wrap {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    overflow: hidden;
  }
  .koraa-carousel__video-wrap video,
  .koraa-carousel__video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
  }
  .koraa-carousel__image--desktop { display: block !important; }
  .koraa-carousel__image--mobile { display: none !important; }
  @media screen and (max-width: 749px) {
    .koraa-carousel__image--desktop { display: none !important; }
    .koraa-carousel__image--mobile { display: block !important; }
    .koraa-carousel__slide {
      min-height: {{ section.settings.hero_height_mobile | default: 100 }}svh;
      min-height: {{ section.settings.hero_height_mobile | default: 100 }}vh; /* fallback */
    }
    /* Adjust bottom content padding to account for bottom nav */
    .koraa-carousel__content--bottom-left,
    .koraa-carousel__content--bottom-right,
    .koraa-carousel__content--bottom-center {
      padding-bottom: 90px;
    }
  }

  .koraa-carousel__placeholder {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    background: #e5e5e5;
  }

  /* Overlay */
  .koraa-carousel__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* Content positioning */
  .koraa-carousel__content {
    position: absolute;
    z-index: 2;
    max-width: 600px;
  }
  .koraa-carousel__content--bottom-left {
    bottom: 0; left: 0; padding: 48px; text-align: left;
  }
  .koraa-carousel__content--bottom-center {
    bottom: 0; left: 50%; transform: translateX(-50%); padding: 48px; text-align: center;
  }
  .koraa-carousel__content--center {
    top: 50%; left: 50%; transform: translate(-50%, -50%); padding: 48px; text-align: center; max-width: 80%;
  }
  .koraa-carousel__content--bottom-right {
    bottom: 0; right: 0; padding: 48px; text-align: right;
  }
  @media screen and (max-width: 749px) {
    .koraa-carousel__content--bottom-left,
    .koraa-carousel__content--bottom-right,
    .koraa-carousel__content--bottom-center { padding: 28px 20px; }
    .koraa-carousel__content--center { padding: 20px; }
    .koraa-carousel__heading { font-size: 28px !important; }
    .koraa-carousel__subtitle { font-size: 9px !important; }
    .koraa-carousel__desc { font-size: 12px !important; }
  }

  /* Typography */
  .koraa-carousel__subtitle {
    display: block; letter-spacing: 0.15em; text-transform: uppercase;
    font-weight: 500; margin-bottom: 10px; opacity: 0.9;
  }
  .koraa-carousel__heading {
    font-weight: 800; line-height: 1.05; text-transform: uppercase; margin: 0 0 12px 0;
  }
  .koraa-carousel__desc {
    margin: 0 0 20px 0; opacity: 0.85; line-height: 1.5;
  }
  .koraa-carousel__cta {
    display: inline-block; padding: 12px 28px; font-size: 11px;
    letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;
    text-decoration: none !important; transition: all 0.3s ease; cursor: pointer;
    color: inherit !important; min-height: auto !important;
  }
  .koraa-carousel__cta:hover {
    opacity: 0.8; transform: translateY(-1px);
  }

  /* Dots */
  .koraa-carousel__dots {
    position: absolute; bottom: 16px; left: 50%;
    transform: translateX(-50%); z-index: 10; display: flex; gap: 8px;
  }
  .koraa-carousel__dot {
    width: 8px; height: 8px; border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.7); background: transparent;
    cursor: pointer; padding: 0; transition: all 0.3s ease;
    min-height: auto !important; min-width: auto !important;
  }
  .koraa-carousel__dot.is-active {
    background: #fff; transform: scale(1.2);
  }

  /* ===== PREMIUM CINEMATIC TRANSITIONS ===== */

  /* 1. CROSSFADE — Smooth cinematic dissolve */
  [data-effect="crossfade"] .koraa-carousel__slide {
    transition: opacity 1.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* 2. SLIDE — Silky horizontal glide */
  [data-effect="slide"] .koraa-carousel__slide {
    transform: translateX(100%);
    opacity: 1;
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s ease;
  }
  [data-effect="slide"] .koraa-carousel__slide.is-active { 
    transform: translateX(0); opacity: 1; 
  }
  [data-effect="slide"] .koraa-carousel__slide.is-exiting { 
    transform: translateX(-100%); opacity: 1; 
  }

  /* 3. BLUR FADE — Cinematic rack focus */
  [data-effect="blur-fade"] .koraa-carousel__slide {
    filter: blur(16px); 
    transform: scale(0.96);
    transition: opacity 1s ease, filter 1.2s cubic-bezier(0.16, 1, 0.3, 1), transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  [data-effect="blur-fade"] .koraa-carousel__slide.is-active { 
    filter: blur(0); transform: scale(1); 
  }
  [data-effect="blur-fade"] .koraa-carousel__slide.is-exiting { 
    filter: blur(16px); transform: scale(1.04); opacity: 0; 
  }

  /* 4. SCALE FADE — Dolly zoom dissolve */
  [data-effect="scale-fade"] .koraa-carousel__slide {
    transform: scale(1.12);
    transition: opacity 1s ease, transform 1.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  [data-effect="scale-fade"] .koraa-carousel__slide.is-active { transform: scale(1); }
  [data-effect="scale-fade"] .koraa-carousel__slide.is-exiting { transform: scale(0.88); opacity: 0; }

  /* 5. KEN BURNS — Cinematic slow zoom */
  [data-effect="ken-burns"] .koraa-carousel__slide { 
    transition: opacity 1.5s cubic-bezier(0.4, 0, 0.2, 1); 
  }
  [data-effect="ken-burns"] .koraa-carousel__slide.is-active .koraa-carousel__image {
    animation: kenBurns 10s ease-in-out forwards;
  }
  @keyframes kenBurns { from { transform: scale(1); } to { transform: scale(1.1); } }

  /* 6. VERTICAL SLIDE — Smooth vertical reveal (NEW) */
  [data-effect="slide-up"] .koraa-carousel__slide {
    transform: translateY(100%);
    opacity: 1;
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
  }
  [data-effect="slide-up"] .koraa-carousel__slide.is-active { 
    transform: translateY(0); opacity: 1; 
  }
  [data-effect="slide-up"] .koraa-carousel__slide.is-exiting { 
    transform: translateY(-100%); opacity: 1; 
  }

  /* 7. PARALLAX — Layered depth motion (NEW) */
  [data-effect="parallax"] .koraa-carousel__slide {
    transform: translateX(100%) scale(1.1);
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s ease;
    opacity: 1;
  }
  [data-effect="parallax"] .koraa-carousel__slide.is-active { 
    transform: translateX(0) scale(1); opacity: 1; 
  }
  [data-effect="parallax"] .koraa-carousel__slide.is-exiting { 
    transform: translateX(-40%) scale(0.95); opacity: 0; 
  }
  [data-effect="parallax"] .koraa-carousel__slide.is-active .koraa-carousel__image {
    animation: parallaxZoom 8s ease-in-out forwards;
  }
  @keyframes parallaxZoom { from { transform: scale(1.05); } to { transform: scale(1); } }

  /* 8. CINEMA WIPE — Elegant reveal wipe (NEW) */
  [data-effect="wipe"] .koraa-carousel__slide {
    clip-path: inset(0 100% 0 0);
    opacity: 1;
    transition: clip-path 1.2s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }
  [data-effect="wipe"] .koraa-carousel__slide.is-active { 
    clip-path: inset(0 0 0 0); opacity: 1; 
  }
  [data-effect="wipe"] .koraa-carousel__slide.is-exiting { 
    clip-path: inset(0 0 0 100%); opacity: 1; 
  }
</style>

<script>
  /* Koraa Carousel — Editor-aware, re-initializable */
  (function() {
    function initCarousel(container) {
      var el = container ? container.querySelector('#koraa-carousel') : document.getElementById('koraa-carousel');
      if (!el) return;
      var slides = el.querySelectorAll('.koraa-carousel__slide');
      var dots = el.querySelectorAll('.koraa-carousel__dot');

      var speed = parseInt(el.dataset.speed, 10) * 1000 || 5000;
      var effect = el.dataset.effect || 'crossfade';
      var autoplay = el.dataset.autoplay === 'true';
      var current = 0, busy = false, timer = null;
      var isEditorMode = window.Shopify && window.Shopify.designMode;

      // Find which slide is currently active (from Liquid)
      slides.forEach(function(s, i) {
        if (s.classList.contains('is-active')) current = i;
      });

      // Handle video play/pause for slide transitions
      function handleSlideVideos(activeIndex) {
        slides.forEach(function(s, idx) {
          var videos = s.querySelectorAll('video');
          videos.forEach(function(v) {
            if (idx === activeIndex) {
              v.play().catch(function() {});
            } else {
              v.pause();
              v.currentTime = 0;
            }
          });
        });
      }

      function showSlide(index) {
        if (index < 0 || index >= slides.length) return;
        slides.forEach(function(s) { s.classList.remove('is-active', 'is-exiting'); });
        dots.forEach(function(d) { d.classList.remove('is-active'); });
        slides[index].classList.add('is-active');
        if (dots[index]) dots[index].classList.add('is-active');
        current = index;
        busy = false;
        handleSlideVideos(index);
      }

      function goTo(i) {
        if (busy || i === current || slides.length <= 1) return;
        busy = true;
        var prev = current; current = i;
        slides[prev].classList.add('is-exiting');
        slides[prev].classList.remove('is-active');
        if (dots[prev]) dots[prev].classList.remove('is-active');
        setTimeout(function() {
          slides[current].classList.add('is-active');
          if (dots[current]) dots[current].classList.add('is-active');
          handleSlideVideos(current);
        }, 30);
        setTimeout(function() {
          slides[prev].classList.remove('is-exiting');
          busy = false;
        }, 1000);
      }

      // Dot click
      dots.forEach(function(d, i) {
        d.addEventListener('click', function() { goTo(i); resetTimer(); });
      });

      // Touch swipe
      var sx = 0;
      el.addEventListener('touchstart', function(e) { sx = e.changedTouches[0].screenX; }, {passive:true});
      el.addEventListener('touchend', function(e) {
        var diff = sx - e.changedTouches[0].screenX;
        if (Math.abs(diff) > 50) {
          goTo(diff > 0 ? (current+1) % slides.length : (current-1+slides.length) % slides.length);
          resetTimer();
        }
      }, {passive:true});

      // Autoplay
      function startTimer() {
        clearInterval(timer);
        if (autoplay && slides.length > 1) {
          timer = setInterval(function() { goTo((current+1) % slides.length); }, speed);
        }
      }
      function resetTimer() { clearInterval(timer); startTimer(); }
      startTimer();

      // Store cleanup function
      el._carouselCleanup = function() { clearInterval(timer); };
      el._carouselShowSlide = showSlide;
      
      // Ensure the initial active slide's video starts playing
      handleSlideVideos(current);
    }

    // Initialize on page load
    initCarousel();

    // ===== SHOPIFY THEME EDITOR EVENTS =====

    // Re-initialize when section is loaded/re-rendered (image upload, setting change)
    document.addEventListener('shopify:section:load', function(e) {
      initCarousel(e.target);
    });

    // Show selected slide in editor
    document.addEventListener('shopify:block:select', function(e) {
      var carousel = document.getElementById('koraa-carousel');
      if (!carousel || !carousel.contains(e.target)) return;

      var slides = carousel.querySelectorAll('.koraa-carousel__slide');
      for (var i = 0; i < slides.length; i++) {
        if (slides[i] === e.target || slides[i].contains(e.target)) {
          if (carousel._carouselCleanup) carousel._carouselCleanup();
          if (carousel._carouselShowSlide) carousel._carouselShowSlide(i);
          break;
        }
      }
    });

    // Resume autoplay when block deselected
    document.addEventListener('shopify:block:deselect', function(e) {
      var carousel = document.getElementById('koraa-carousel');
      if (!carousel || !carousel.contains(e.target)) return;
      // Re-initialize to resume autoplay
      initCarousel();
    });
  })();
</script>

{% schema %}
{
  "name": "Koraa Hero Banner",
  "settings": [
    {
      "type": "header",
      "content": "Carousel Settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-play Slides",
      "default": true
    },
    {
      "type": "range",
      "id": "slide_duration",
      "label": "Slide Duration (seconds)",
      "min": 2,
      "max": 15,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "select",
      "id": "transition_effect",
      "label": "Transition Effect",
      "options": [
        { "value": "crossfade", "label": "✨ Crossfade (Cinematic Dissolve)" },
        { "value": "slide", "label": "➡️ Slide (Silky Horizontal)" },
        { "value": "slide-up", "label": "⬆️ Slide Up (Vertical Reveal)" },
        { "value": "blur-fade", "label": "🎬 Blur Fade (Rack Focus)" },
        { "value": "scale-fade", "label": "🔍 Scale Fade (Dolly Zoom)" },
        { "value": "ken-burns", "label": "📷 Ken Burns (Slow Zoom)" },
        { "value": "parallax", "label": "🌊 Parallax (Depth Motion)" },
        { "value": "wipe", "label": "🎞️ Cinema Wipe (Reveal)" }
      ],
      "default": "crossfade"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "range",
      "id": "global_overlay",
      "label": "Global Overlay Opacity (%)",
      "info": "Applies to all slides. Individual slide overlay will override this.",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 20
    },
    {
      "type": "header",
      "content": "Hero Height"
    },
    {
      "type": "range",
      "id": "hero_height_desktop",
      "label": "Desktop Height (vh)",
      "info": "Percentage of screen height. 100 = full screen.",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 100
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "label": "Mobile Height (vh)",
      "info": "Percentage of screen height. 100 = full screen.",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Images & Videos"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image",
          "info": "Recommended: 1920x1080px. If a desktop video is also set, the video will take priority."
        },
        {
          "type": "video",
          "id": "video_desktop",
          "label": "Desktop Video",
          "info": "Upload an MP4 video. This will override the desktop image if set."
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile Image",
          "info": "Recommended: 750x1200px (portrait). If a mobile video is also set, the video will take priority."
        },
        {
          "type": "video",
          "id": "video_mobile",
          "label": "Mobile Video",
          "info": "Upload a vertical MP4 video for mobile. Falls back to desktop video if not set."
        },
        {
          "type": "header",
          "content": "Text Content"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "NEW COLLECTION"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Artisanal Clothing"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Shop handmade styles you'll cherish"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button Style",
          "options": [
            { "value": "outline", "label": "Outline (Transparent)" },
            { "value": "solid-white", "label": "Solid White" },
            { "value": "solid-black", "label": "Solid Black" }
          ],
          "default": "outline"
        },
        {
          "type": "header",
          "content": "Typography & Colors"
        },
