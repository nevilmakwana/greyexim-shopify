<!-- Koraa-Style Split Hero (Two Column) -->
<div class="koraa-split-hero">
  {% for block in section.blocks %}
    <div class="koraa-split-hero__panel" {{ block.shopify_attributes }}>
      {% if block.settings.image %}
        <img class="koraa-split-hero__image" src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.heading }}" loading="eager">
      {% else %}
        {% if forloop.index == 1 %}
          <img class="koraa-split-hero__image" src="https://images.unsplash.com/photo-1544413660-299165566b1d?q=80&w=1200&auto=format" alt="{{ block.settings.heading }}" loading="eager" style="object-position: center 30%;">
        {% else %}
          <img class="koraa-split-hero__image" src="https://images.unsplash.com/photo-1509631179647-0177331693ae?w=1200&q=80&auto=format" alt="{{ block.settings.heading }}" loading="eager">
        {% endif %}
      {% endif %}
      <div class="koraa-split-hero__overlay">
        {% if block.settings.subtitle != blank %}
          <span class="koraa-split-hero__subtitle">{{ block.settings.subtitle }}</span>
        {% endif %}
        <h2 class="koraa-split-hero__title">{{ block.settings.heading }}</h2>
        {% if block.settings.description != blank %}
          <p class="koraa-split-hero__desc">{{ block.settings.description }}</p>
        {% endif %}
        <div class="koraa-split-hero__buttons">
          {% if block.settings.button_1_label != blank %}
            <a href="{{ block.settings.button_1_link }}" class="koraa-split-hero__cta">{{ block.settings.button_1_label }}</a>
          {% endif %}
          {% if block.settings.button_2_label != blank %}
            <a href="{{ block.settings.button_2_link }}" class="koraa-split-hero__cta">{{ block.settings.button_2_label }}</a>
          {% endif %}
        </div>
      </div>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Koraa Split Hero",
  "settings": [],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "limit": 2,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "HELLO PIEDMONT AVE" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "OPEN IN OAKLAND!" },
        { "type": "text", "id": "description", "label": "Description", "default": "Visit us at 4167 Piedmont Ave, Oakland" },
        { "type": "text", "id": "button_1_label", "label": "Button 1 Label" },
        { "type": "url", "id": "button_1_link", "label": "Button 1 Link" },
        { "type": "text", "id": "button_2_label", "label": "Button 2 Label" },
        { "type": "url", "id": "button_2_link", "label": "Button 2 Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Koraa Split Hero",
      "blocks": [
        { "type": "panel", "settings": { "subtitle": "HELLO PIEDMONT AVE", "heading": "OPEN IN OAKLAND!", "description": "Visit us at 4167 Piedmont Ave, Oakland" } },
        { "type": "panel", "settings": { "subtitle": "SHOP", "heading": "BOGO SALE", "description": "BUY ONE GET ONE FREE\nAll Rover & Kin accessories!", "button_1_label": "EARRINGS", "button_2_label": "NECKLACES" } }
      ]
    }
  ]
}
{% endschema %}
