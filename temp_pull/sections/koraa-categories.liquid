<!-- Koraa-Style Category Grid Section -->
{% assign placeholder_images = "https://images.unsplash.com/photo-1595079676339-1534801ad6cf?w=600&q=80&auto=format,https://images.unsplash.com/photo-1584346133934-a3afd2a33c4c?w=600&q=80&auto=format,https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=600&q=80&auto=format,https://images.unsplash.com/photo-1565193566173-7a0ee3dbe261?w=600&q=80&auto=format" | split: "," %}

<div class="koraa-categories koraa-section">
  <div class="koraa-section-header koraa-section-header--centered">
    <h2>{{ section.settings.heading }}</h2>
  </div>
  <div class="koraa-categories__grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="koraa-category-card" {{ block.shopify_attributes }}>
        <div class="koraa-category-card__wrapper">
          {% if block.settings.image %}
            <img class="koraa-category-card__image" src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title }}" loading="lazy">
          {% else %}
            <img class="koraa-category-card__image" src="{{ placeholder_images[forloop.index0] }}" alt="{{ block.settings.title }}" loading="lazy">
          {% endif %}
          <div class="koraa-category-card__label">
            <span>{{ block.settings.title }}</span>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Koraa Category Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Shop home + kitchen"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Category Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Category Name" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Koraa Category Grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Baskets + Organization" } },
        { "type": "category", "settings": { "title": "Throw Pillows" } },
        { "type": "category", "settings": { "title": "Felt Flowers + Vases" } },
        { "type": "category", "settings": { "title": "Ceramics + Kitchen" } }
      ]
    }
  ]
}
{% endschema %}
