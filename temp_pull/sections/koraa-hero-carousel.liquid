<!-- Koraa Hero Carousel — Multi-Slide with Full Controls -->
<div 
  class="koraa-carousel" 
  id="koraa-carousel"
  data-speed="{{ section.settings.slide_duration }}"
  data-effect="{{ section.settings.transition_effect }}"
  data-autoplay="{{ section.settings.autoplay }}"
>
  {%- comment -%} Progress/Dots Navigation {%- endcomment -%}
  {% if section.blocks.size > 1 %}
    <div class="koraa-carousel__dots">
      {% for block in section.blocks %}
        <button 
          class="koraa-carousel__dot {% if forloop.first %}is-active{% endif %}" 
          data-index="{{ forloop.index0 }}"
          aria-label="Slide {{ forloop.index }}"
        ></button>
      {% endfor %}
    </div>
  {% endif %}

  {%- comment -%} Slides {%- endcomment -%}
  <div class="koraa-carousel__track">
    {% for block in section.blocks %}
      {%- liquid
        assign text_color = block.settings.text_color | default: '#ffffff'
        assign overlay_opacity = block.settings.overlay_opacity | default: 30
        assign text_position = block.settings.text_position | default: 'bottom-left'
        assign heading_size = block.settings.heading_size | default: 42
        assign subtitle_size = block.settings.subtitle_size | default: 11
        assign desc_size = block.settings.desc_size | default: 14
      -%}

      <div 
        class="koraa-carousel__slide {% if forloop.first %}is-active{% endif %}" 
        {{ block.shopify_attributes }}
        style="color: {{ text_color }};"
      >
        {%- comment -%} Desktop Image {%- endcomment -%}
        {% if block.settings.image %}
          <img 
            class="koraa-carousel__image koraa-carousel__image--desktop"
            src="{{ block.settings.image | image_url: width: 2000 }}"
            alt="{{ block.settings.heading | escape }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          >
        {% else %}
          <div class="koraa-carousel__placeholder"></div>
        {% endif %}

        {%- comment -%} Mobile Image {%- endcomment -%}
        {% if block.settings.image_mobile %}
          <img 
            class="koraa-carousel__image koraa-carousel__image--mobile"
            src="{{ block.settings.image_mobile | image_url: width: 1000 }}"
            alt="{{ block.settings.heading | escape }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          >
        {% elsif block.settings.image %}
          <img 
            class="koraa-carousel__image koraa-carousel__image--mobile"
            src="{{ block.settings.image | image_url: width: 1000 }}"
            alt="{{ block.settings.heading | escape }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          >
        {% endif %}

        {%- comment -%} Overlay {%- endcomment -%}
        <div class="koraa-carousel__overlay" style="background: rgba(0,0,0,{{ overlay_opacity | divided_by: 100.0 }});"></div>

        {%- comment -%} Text Content {%- endcomment -%}
        <div class="koraa-carousel__content koraa-carousel__content--{{ text_position }}">
          {% if block.settings.subtitle != blank %}
            <span 
              class="koraa-carousel__subtitle"
              style="font-size: {{ subtitle_size }}px;"
            >{{ block.settings.subtitle }}</span>
          {% endif %}

          {% if block.settings.heading != blank %}
            <h2 
              class="koraa-carousel__heading"
              style="font-size: {{ heading_size }}px;"
            >{{ block.settings.heading }}</h2>
          {% endif %}

          {% if block.settings.description != blank %}
            <p 
              class="koraa-carousel__desc"
              style="font-size: {{ desc_size }}px;"
            >{{ block.settings.description }}</p>
          {% endif %}

          {% if block.settings.button_label != blank %}
            <a 
              href="{{ block.settings.button_link }}" 
              class="koraa-carousel__cta"
              style="
                {% if block.settings.button_style == 'outline' %}
                  background: transparent; border: 1.5px solid {{ text_color }}; color: {{ text_color }};
                {% elsif block.settings.button_style == 'solid-white' %}
                  background: #ffffff; border: none; color: #000000;
                {% elsif block.settings.button_style == 'solid-black' %}
                  background: #000000; border: none; color: #ffffff;
                {% else %}
                  background: transparent; border: 1.5px solid {{ text_color }}; color: {{ text_color }};
                {% endif %}
              "
            >{{ block.settings.button_label }}</a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .koraa-carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .koraa-carousel__track {
    display: grid;
    width: 100%;
  }

  .koraa-carousel__slide {
    grid-area: 1 / 1;
    position: relative;
    width: 100%;
    opacity: 0;
    pointer-events: none;
    will-change: opacity, transform;
  }
  .koraa-carousel__slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Images */
  .koraa-carousel__image {
    width: 100%;
    height: 100vh;
    display: block;
    object-fit: cover;
  }
  .koraa-carousel__image--desktop { display: block !important; }
  .koraa-carousel__image--mobile { display: none !important; }

  @media screen and (max-width: 749px) {
    .koraa-carousel__image--desktop { display: none !important; }
    .koraa-carousel__image--mobile { 
      display: block !important; 
      height: 85vh; 
      object-fit: cover;
    }
  }

  .koraa-carousel__placeholder {
    width: 100%;
    height: 70vh;
    background: #e5e5e5;
  }

  /* Overlay */
  .koraa-carousel__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* Content positioning */
  .koraa-carousel__content {
    position: absolute;
    z-index: 2;
    max-width: 600px;
  }
  .koraa-carousel__content--bottom-left {
    bottom: 0; left: 0;
    padding: 48px;
    text-align: left;
  }
  .koraa-carousel__content--bottom-center {
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    padding: 48px;
    text-align: center;
  }
  .koraa-carousel__content--center {
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    padding: 48px;
    text-align: center;
    max-width: 80%;
  }
  .koraa-carousel__content--bottom-right {
    bottom: 0; right: 0;
    padding: 48px;
    text-align: right;
  }

  @media screen and (max-width: 749px) {
    .koraa-carousel__content--bottom-left,
    .koraa-carousel__content--bottom-right,
    .koraa-carousel__content--bottom-center {
      padding: 28px 20px;
    }
    .koraa-carousel__content--center {
      padding: 20px;
    }
  }

  /* Text styles */
  .koraa-carousel__subtitle {
    display: block;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 10px;
    opacity: 0.9;
  }
  .koraa-carousel__heading {
    font-weight: 800;
    line-height: 1.05;
    text-transform: uppercase;
    margin: 0 0 12px 0;
  }
  @media screen and (max-width: 749px) {
    .koraa-carousel__heading {
      font-size: 28px !important;
    }
    .koraa-carousel__subtitle {
      font-size: 9px !important;
    }
    .koraa-carousel__desc {
      font-size: 12px !important;
    }
  }
  .koraa-carousel__desc {
    margin: 0 0 20px 0;
    opacity: 0.85;
    line-height: 1.5;
  }
  .koraa-carousel__cta {
    display: inline-block;
    padding: 12px 28px;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    text-decoration: none !important;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .koraa-carousel__cta:hover {
    opacity: 0.8;
    transform: translateY(-1px);
  }

  /* Dots */
  .koraa-carousel__dots {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 8px;
  }
  .koraa-carousel__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.7);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
    min-height: auto !important;
    min-width: auto !important;
  }
  .koraa-carousel__dot.is-active {
    background: #ffffff;
    transform: scale(1.2);
  }

  /* ===== TRANSITIONS ===== */
  
  /* Crossfade */
  [data-effect="crossfade"] .koraa-carousel__slide {
    transition: opacity 0.9s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Slide */
  [data-effect="slide"] .koraa-carousel__slide {
    transform: translateX(100%);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  [data-effect="slide"] .koraa-carousel__slide.is-active {
    transform: translateX(0);
  }
  [data-effect="slide"] .koraa-carousel__slide.is-exiting {
    transform: translateX(-100%);
    opacity: 0;
  }

  /* Blur Fade */
  [data-effect="blur-fade"] .koraa-carousel__slide {
    filter: blur(12px);
    transform: scale(0.95);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  [data-effect="blur-fade"] .koraa-carousel__slide.is-active {
    filter: blur(0);
    transform: scale(1);
  }
  [data-effect="blur-fade"] .koraa-carousel__slide.is-exiting {
    filter: blur(12px);
    transform: scale(1.05);
    opacity: 0;
  }

  /* Scale Fade */
  [data-effect="scale-fade"] .koraa-carousel__slide {
    transform: scale(1.15);
    transition: all 0.85s cubic-bezier(0.22, 1, 0.36, 1);
  }
  [data-effect="scale-fade"] .koraa-carousel__slide.is-active {
    transform: scale(1);
  }
  [data-effect="scale-fade"] .koraa-carousel__slide.is-exiting {
    transform: scale(0.9);
    opacity: 0;
  }

  /* Ken Burns (subtle zoom) */
  [data-effect="ken-burns"] .koraa-carousel__slide {
    transition: opacity 1.2s ease;
  }
  [data-effect="ken-burns"] .koraa-carousel__slide.is-active .koraa-carousel__image {
    animation: kenBurns 8s ease-in-out forwards;
  }
  @keyframes kenBurns {
    from { transform: scale(1); }
    to { transform: scale(1.08); }
  }
</style>

<script>
  (function() {
    var carousel = document.getElementById('koraa-carousel');
    if (!carousel) return;

    var slides = carousel.querySelectorAll('.koraa-carousel__slide');
    var dots = carousel.querySelectorAll('.koraa-carousel__dot');
    if (slides.length <= 1) return;

    var speed = parseInt(carousel.dataset.speed, 10) * 1000 || 5000;
    var effect = carousel.dataset.effect || 'crossfade';
    var autoplay = carousel.dataset.autoplay === 'true';
    var current = 0;
    var busy = false;
    var timer = null;

    function goTo(index) {
      if (busy || index === current) return;
      busy = true;

      var prev = current;
      current = index;

      // Exit old
      slides[prev].classList.add('is-exiting');
      slides[prev].classList.remove('is-active');
      if (dots[prev]) dots[prev].classList.remove('is-active');

      // Enter new
      setTimeout(function() {
        slides[current].classList.add('is-active');
        if (dots[current]) dots[current].classList.add('is-active');
      }, 30);

      // Cleanup
      setTimeout(function() {
        slides[prev].classList.remove('is-exiting');
        busy = false;
      }, 1000);
    }

    function next() {
      goTo((current + 1) % slides.length);
    }

    // Dot clicks
    dots.forEach(function(dot, i) {
      dot.addEventListener('click', function() {
        goTo(i);
        resetTimer();
      });
    });

    // Touch swipe support
    var touchStartX = 0;
    carousel.addEventListener('touchstart', function(e) {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    carousel.addEventListener('touchend', function(e) {
      var diff = touchStartX - e.changedTouches[0].screenX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) {
          goTo((current + 1) % slides.length);
        } else {
          goTo((current - 1 + slides.length) % slides.length);
        }
        resetTimer();
      }
    }, { passive: true });

    // Autoplay
    function startTimer() {
      if (autoplay) {
        timer = setInterval(next, speed);
      }
    }
    function resetTimer() {
      clearInterval(timer);
      startTimer();
    }

    startTimer();
  })();
</script>

{% schema %}
{
  "name": "Koraa Hero Carousel",
  "settings": [
    {
      "type": "header",
      "content": "Carousel Settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-play Slides",
      "default": true
    },
    {
      "type": "range",
      "id": "slide_duration",
      "label": "Slide Duration (seconds)",
      "min": 2,
      "max": 15,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "select",
      "id": "transition_effect",
      "label": "Transition Effect",
      "options": [
        { "value": "crossfade", "label": "✨ Crossfade (Dissolve)" },
        { "value": "slide", "label": "➡️ Slide (Horizontal)" },
        { "value": "blur-fade", "label": "🎬 Blur Fade (Cinematic)" },
        { "value": "scale-fade", "label": "🔍 Scale Fade (Zoom)" },
        { "value": "ken-burns", "label": "📷 Ken Burns (Slow Zoom)" }
      ],
      "default": "crossfade"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Images"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image",
          "info": "Recommended: 1920x1080px"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile Image",
          "info": "Recommended: 750x1200px (portrait)"
        },
        {
          "type": "header",
          "content": "Text Content"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "NEW COLLECTION"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Artisanal Clothing"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Shop handmade styles you'll cherish"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button Style",
          "options": [
            { "value": "outline", "label": "Outline (Transparent)" },
            { "value": "solid-white", "label": "Solid White" },
            { "value": "solid-black", "label": "Solid Black" }
          ],
          "default": "outline"
        },
        {
          "type": "header",
          "content": "Typography & Colors"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#ffffff"
        },
        {
          "type": "range",
          "id": "heading_size",
          "label": "Heading Size (px)",
          "min": 20,
          "max": 80,
          "step": 2,
          "unit": "px",
          "default": 42
        },
        {
          "type": "range",
          "id": "subtitle_size",
          "label": "Subtitle Size (px)",
          "min": 8,
          "max": 18,
          "step": 1,
          "unit": "px",
          "default": 11
        },
        {
          "type": "range",
          "id": "desc_size",
          "label": "Description Size (px)",
          "min": 10,
          "max": 22,
          "step": 1,
          "unit": "px",
          "default": 14
        },
        {
          "type": "header",
          "content": "Layout"
        },
        {
          "type": "select",
          "id": "text_position",
          "label": "Text Position",
          "options": [
            { "value": "bottom-left", "label": "Bottom Left" },
            { "value": "bottom-center", "label": "Bottom Center" },
            { "value": "bottom-right", "label": "Bottom Right" },
            { "value": "center", "label": "Center" }
          ],
          "default": "bottom-left"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay Darkness (%)",
          "min": 0,
          "max": 80,
          "step": 5,
          "unit": "%",
          "default": 30
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Koraa Hero Carousel",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "subtitle": "SPRING HAS ARRIVED",
            "heading": "Artisanal Clothing",
            "description": "Shop handmade styles you'll cherish",
            "button_label": "Shop Apparel"
          }
        }
      ]
    }
  ]
}
{% endschema %}
