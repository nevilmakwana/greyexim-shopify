<style>
  /* Wishlist Drawer - Premium Glassmorphism */
  .wishlist-drawer-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 9998;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }
  .wishlist-drawer-overlay.is-active {
    opacity: 1;
    visibility: visible;
  }

  .wishlist-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: 85vw;
    max-width: 400px;
    height: 100vh;
    height: 100dvh;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(40px) saturate(200%);
    -webkit-backdrop-filter: blur(40px) saturate(200%);
    z-index: 9999;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -10px 0 30px rgba(0,0,0,0.1);
  }
  
  .wishlist-drawer.is-active {
    transform: translateX(0);
  }

  .wishlist-drawer__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .wishlist-drawer__title {
    font-size: 20px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
    letter-spacing: -0.5px;
  }

  .wishlist-drawer__close {
    background: rgba(0,0,0,0.05);
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s;
  }
  
  .wishlist-drawer__close:active {
    background: rgba(0,0,0,0.1);
  }

  .wishlist-drawer__content {
    flex: 1;
    overflow-y: auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    -webkit-overflow-scrolling: touch;
  }

  .wishlist-drawer__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    text-align: center;
    color: #666;
    gap: 16px;
  }
  
  .wishlist-drawer__empty svg {
    width: 48px;
    height: 48px;
    stroke: #ccc;
  }

  .wishlist-item {
    display: flex;
    gap: 16px;
    background: #ffffff;
    border-radius: 16px;
    padding: 12px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
    position: relative;
    transition: transform 0.3s ease;
  }

  .wishlist-item__image {
    width: 80px;
    height: 100px;
    border-radius: 10px;
    object-fit: cover;
    background: #f5f5f5;
  }

  .wishlist-item__info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .wishlist-item__title {
    font-size: 14px;
    font-weight: 500;
    color: #111;
    margin: 0 0 4px 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .wishlist-item__price {
    font-size: 14px;
    font-weight: 600;
    color: #333;
    margin: 0 0 12px 0;
  }

  .wishlist-item__actions {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .wishlist-item__add-btn {
    flex: 1;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 8px 0;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .wishlist-item__add-btn:active {
    transform: scale(0.96);
    background: #333;
  }
  
  .wishlist-item__add-btn.is-loading {
    opacity: 0.7;
    pointer-events: none;
  }

  .wishlist-item__remove-btn {
    background: rgba(231, 76, 60, 0.1);
    color: #e74c3c;
    border: none;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .wishlist-item__remove-btn:active {
    transform: scale(0.92);
    background: rgba(231, 76, 60, 0.2);
  }
</style>

<div class="wishlist-drawer-overlay" id="wishlistDrawerOverlay"></div>
<div class="wishlist-drawer" id="wishlistDrawer">
  <div class="wishlist-drawer__header">
    <h2 class="wishlist-drawer__title">Wishlist</h2>
    <button class="wishlist-drawer__close" id="closeWishlistDrawer" aria-label="Close wishlist">
      <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <div class="wishlist-drawer__content" id="wishlistDrawerContent">
    <!-- Items rendered here by JS -->
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const drawer = document.getElementById('wishlistDrawer');
    const overlay = document.getElementById('wishlistDrawerOverlay');
    const closeBtn = document.getElementById('closeWishlistDrawer');
    const content = document.getElementById('wishlistDrawerContent');
    
    // Add event listeners for opening the drawer
    document.body.addEventListener('click', (e) => {
      const openBtn = e.target.closest('#openWishlistDrawer');
      if (openBtn) {
        e.preventDefault();
        openDrawer();
      }
    });

    closeBtn.addEventListener('click', closeDrawer);
    overlay.addEventListener('click', closeDrawer);

    function openDrawer() {
      renderWishlistItems();
      drawer.classList.add('is-active');
      overlay.classList.add('is-active');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.classList.remove('is-active');
      overlay.classList.remove('is-active');
      document.body.style.overflow = '';
    }

    function getWishlistData() {
      try { return JSON.parse(localStorage.getItem('greyexim_wishlist')) || []; }
      catch(e) { return []; }
    }

    function removeWishlistItem(id) {
      let list = getWishlistData();
      list = list.filter(item => String(item.id) !== String(id));
      localStorage.setItem('greyexim_wishlist', JSON.stringify(list));
      
      // Update global badges if function exists
      if (typeof window.updateBadge === 'function') window.updateBadge();
      else if (typeof updateBadge === 'function') updateBadge();
      
      // Uncheck heart on page if present
      document.querySelectorAll(`.product-title-wishlist-btn[data-product-id="${id}"]`).forEach(b => {
        b.classList.remove('is-wishlisted');
      });

      renderWishlistItems();
    }

    window.addWishlistItemToCart = function(btn, variantId) {
      if (!variantId) return;
      btn.classList.add('is-loading');
      btn.textContent = 'Adding...';

      let formData = {
        'items': [{
          'id': variantId,
          'quantity': 1
        }]
      };

      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(formData)
      })
      .then(response => {
        if (!response.ok) throw new Error('Error adding to cart');
        return response.json();
      })
      .then(data => {
        btn.textContent = 'Redirecting...';
        
        // Try to update global cart badge if it exists
        if (typeof window.updateCartBadge === 'function') window.updateCartBadge();
        else if (typeof updateCartBadge === 'function') updateCartBadge();

        // Redirect directly to the cart page so the user can immediately order
        window.location.href = window.Shopify.routes.root + 'cart';
      })
      .catch((error) => {
        console.error('Error:', error);
        btn.textContent = 'Error';
        btn.classList.remove('is-loading');
      });
    };

    window.removeWishlistItemGlobal = function(id) {
      removeWishlistItem(id);
    };

    function renderWishlistItems() {
      const items = getWishlistData();
      
      if (items.length === 0) {
        content.innerHTML = `
          <div class="wishlist-drawer__empty">
            <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
            </svg>
            <p>Your wishlist is empty</p>
          </div>
        `;
        return;
      }

      let html = '';
      items.reverse().forEach(item => {
        html += `
          <div class="wishlist-item" data-id="${item.id}">
            <a href="${item.url}">
              <img src="${item.image || '//cdn.shopify.com/s/images/themes/product-1.png'}" alt="" class="wishlist-item__image" loading="lazy">
            </a>
            <div class="wishlist-item__info">
              <a href="${item.url}" style="text-decoration:none;">
                <h3 class="wishlist-item__title">${item.title}</h3>
              </a>
              <p class="wishlist-item__price">${item.price}</p>
              <div class="wishlist-item__actions">
                <button class="wishlist-item__add-btn" onclick="addWishlistItemToCart(this, '${item.variantId}')">Add to Cart</button>
                <button class="wishlist-item__remove-btn" onclick="removeWishlistItemGlobal('${item.id}')" aria-label="Remove">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"></polyline>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        `;
      });
      content.innerHTML = html;
    }
  });
</script>

<script>
  // Global Wishlist Functions
  function koraaGetWishlist() {
    try { return JSON.parse(localStorage.getItem('greyexim_wishlist')) || []; }
    catch(e) { return []; }
  }

  function koraaSaveWishlist(list) {
    localStorage.setItem('greyexim_wishlist', JSON.stringify(list));
    if (typeof window.updateWishlistBadge === 'function') window.updateWishlistBadge();
    if (typeof window.updateBadge === 'function') window.updateBadge();
  }

  function koraaIsInWishlist(productId) {
    return koraaGetWishlist().some(item => String(item.id) === String(productId));
  }

  function handleCustomWishlistClick(e, btn) {
    e.preventDefault();
    e.stopPropagation();
    
    const productId = btn.dataset.productId;
    
    if (koraaIsInWishlist(productId)) {
      const list = koraaGetWishlist().filter(item => String(item.id) !== String(productId));
      koraaSaveWishlist(list);
      btn.classList.remove('is-wishlisted');
      btn.querySelector('svg').style.fill = 'none';
      btn.querySelector('svg').style.stroke = '#111';
      if (typeof showToast === 'function') showToast('Removed from Wishlist');
    } else {
      const list = koraaGetWishlist();
      list.push({
        id: productId,
        variantId: btn.dataset.variantId,
        url: btn.dataset.productUrl,
        title: btn.dataset.productTitle,
        image: btn.dataset.productImage,
        price: btn.dataset.productPrice,
        addedAt: Date.now()
      });
      koraaSaveWishlist(list);
      btn.classList.add('is-wishlisted');
      btn.querySelector('svg').style.fill = '#e74c3c';
      btn.querySelector('svg').style.stroke = '#e74c3c';
      if (typeof showToast === 'function') showToast('Added to Wishlist ♥');
    }
  }

  function handleCustomCartClick(e, productUrl) {
    e.preventDefault();
    e.stopPropagation();
    
    const btn = e.currentTarget;
    if (btn.classList.contains('is-loading')) return;
    
    const originalHTML = btn.innerHTML;
    btn.classList.add('is-loading');
    btn.innerHTML = '<svg style="width: 14px; height: 14px; animation: koraaSpin 1s linear infinite;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="4.93" x2="19.07" y2="7.76"></line></svg>';
    
    // Add keyframes for the spinner if not exists
    if (!document.getElementById('koraa-spin-style')) {
      const style = document.createElement('style');
      style.id = 'koraa-spin-style';
      style.innerHTML = '@keyframes koraaSpin { 100% { transform: rotate(360deg); } }';
      document.head.appendChild(style);
    }
    
    // Restore button after modal opens or timeout
    const restoreBtn = () => {
      btn.innerHTML = originalHTML;
      btn.classList.remove('is-loading');
    };
    
    // Most Shopify themes use custom events for modal open, or we just use a timeout as fallback
    setTimeout(restoreBtn, 800);
    
    const card = e.target.closest('product-card');
    if (card) {
      const quickAddComponent = card.querySelector('quick-add-component');
      const quickAddBtn = card.querySelector('.quick-add__button--choose') || card.querySelector('.quick-add__button--add');
      
      if (quickAddComponent && typeof quickAddComponent.handleClick === 'function') {
        quickAddComponent.handleClick(e);
        return;
      } else if (quickAddBtn) {
        quickAddBtn.click();
        return;
      }
      
      const quickViewBtn = card.querySelector('.koraa-product-card__quickview');
      if (quickViewBtn) {
        quickViewBtn.click();
        return;
      }
    }
    
    window.location.href = productUrl;
  }
  
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.custom-wishlist-trigger').forEach(btn => {
      if (koraaIsInWishlist(btn.dataset.productId)) {
        btn.classList.add('is-wishlisted');
        btn.querySelector('svg').style.fill = '#e74c3c';
        btn.querySelector('svg').style.stroke = '#e74c3c';
      }
    });
  });
</script>
