<!-- H&M-Style Account Drawer -->
<div class="account-drawer-overlay" id="accountDrawerOverlay"></div>
<aside class="account-drawer" id="accountDrawer" aria-label="Account" role="dialog" aria-modal="true">
  <div class="account-drawer__inner">
    <!-- Header -->
    <div class="account-drawer__header">
      <h2 class="account-drawer__title">
        {% if customer %}
          {{ customer.first_name | default: 'My Account' }}
        {% else %}
          Sign in
        {% endif %}
      </h2>
      <button class="account-drawer__close" id="accountDrawerClose" aria-label="Close account drawer">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="4" x2="16" y2="16"></line>
          <line x1="16" y1="4" x2="4" y2="16"></line>
        </svg>
      </button>
    </div>

    <!-- Content -->
    <div class="account-drawer__content">
      {% if customer %}
        <!-- Logged In State -->
        <div class="account-drawer__profile">
          <div class="account-drawer__avatar">
            <span class="account-drawer__avatar-letter">{{ customer.first_name | slice: 0 | upcase | default: 'G' }}</span>
          </div>
          <div class="account-drawer__user-info">
            <p class="account-drawer__user-name">{{ customer.first_name }} {{ customer.last_name }}</p>
            <p class="account-drawer__user-email">{{ customer.email }}</p>
          </div>
        </div>

        <div class="account-drawer__divider"></div>

        <nav class="account-drawer__nav">
          <a href="/account" class="account-drawer__nav-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            <span>My Profile</span>
            <svg class="account-drawer__nav-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </a>
          <a href="/account#orders" class="account-drawer__nav-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <path d="M16 10a4 4 0 0 1-8 0"></path>
            </svg>
            <span>My Orders</span>
            <svg class="account-drawer__nav-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </a>
          <a href="/account#addresses" class="account-drawer__nav-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>Addresses</span>
            <svg class="account-drawer__nav-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </a>
        </nav>

        <div class="account-drawer__divider"></div>

        <div class="account-drawer__footer">
          <a href="/account/logout" class="account-drawer__logout-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
              <polyline points="16 17 21 12 16 7"></polyline>
              <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
            <span>Log out</span>
          </a>
        </div>

      {% else %}
        <!-- Logged Out State -->
        <div class="account-drawer__welcome">
          <div class="account-drawer__welcome-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </div>
          <p class="account-drawer__welcome-text">
            Sign in for a more personalised experience
          </p>
        </div>

        <div class="account-drawer__actions">
          <a href="/account/login" class="account-drawer__signin-btn">
            Sign in
          </a>
          <a href="/account/register" class="account-drawer__register-btn">
            Become a member
          </a>
        </div>

        <div class="account-drawer__divider"></div>

        <div class="account-drawer__benefits">
          <p class="account-drawer__benefits-title">Member benefits</p>
          <ul class="account-drawer__benefits-list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Free shipping on orders over ₹999</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Exclusive offers & early access</span>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>Order tracking & easy returns</span>
            </li>
          </ul>
        </div>
      {% endif %}
    </div>
  </div>
</aside>

<script>
(function() {
  const drawer = document.getElementById('accountDrawer');
  const overlay = document.getElementById('accountDrawerOverlay');
  const closeBtn = document.getElementById('accountDrawerClose');

  function openDrawer() {
    drawer.classList.add('is-open');
    overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer.classList.remove('is-open');
    overlay.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  // Close button
  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
  // Overlay click
  if (overlay) overlay.addEventListener('click', closeDrawer);
  // Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && drawer.classList.contains('is-open')) closeDrawer();
  });

  // Global function to open drawer (used by header & mobile nav)
  window.openAccountDrawer = openDrawer;
  window.closeAccountDrawer = closeDrawer;
})();
</script>

<style>
  /* Account Drawer Overlay */
  .account-drawer-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    z-index: 999;
    pointer-events: none;
    transition: background 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .account-drawer-overlay.is-open {
    background: rgba(0, 0, 0, 0.45);
    pointer-events: all;
  }

  /* Account Drawer */
  .account-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    max-width: 400px;
    background: #fff;
    z-index: 1000;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.08);
  }
  .account-drawer.is-open {
    transform: translateX(0);
  }

  .account-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow-y: auto;
  }

  /* Header */
  .account-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid #e5e5e5;
    flex-shrink: 0;
  }
  .account-drawer__title {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin: 0;
    color: #222;
  }
  .account-drawer__close {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    cursor: pointer;
    border-radius: 50%;
    transition: background 0.2s;
    color: #222;
  }
  .account-drawer__close:hover {
    background: #f5f5f5;
  }

  /* Content */
  .account-drawer__content {
    flex: 1;
    padding: 24px;
    display: flex;
    flex-direction: column;
  }

  /* Divider */
  .account-drawer__divider {
    height: 1px;
    background: #e5e5e5;
    margin: 20px 0;
  }

  /* ========== LOGGED IN STATE ========== */
  .account-drawer__profile {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .account-drawer__avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #222;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .account-drawer__avatar-letter {
    color: #fff;
    font-size: 20px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .account-drawer__user-name {
    font-size: 16px;
    font-weight: 600;
    color: #222;
    margin: 0 0 2px;
  }
  .account-drawer__user-email {
    font-size: 13px;
    color: #777;
    margin: 0;
  }

  /* Nav Items */
  .account-drawer__nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .account-drawer__nav-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 8px;
    text-decoration: none;
    color: #222;
    font-size: 15px;
    font-weight: 500;
    border-radius: 10px;
    transition: background 0.2s;
  }
  .account-drawer__nav-item:hover {
    background: #f5f5f5;
  }
  .account-drawer__nav-arrow {
    margin-left: auto;
    opacity: 0.4;
  }

  /* Logout */
  .account-drawer__footer {
    margin-top: auto;
    padding-top: 8px;
  }
  .account-drawer__logout-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 8px;
    color: #222;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 10px;
    transition: background 0.2s;
  }
  .account-drawer__logout-btn:hover {
    background: #f5f5f5;
  }

  /* ========== LOGGED OUT STATE ========== */
  .account-drawer__welcome {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 24px 0 8px;
  }
  .account-drawer__welcome-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    color: #555;
  }
  .account-drawer__welcome-text {
    font-size: 14px;
    color: #777;
    margin: 0;
    line-height: 1.5;
    max-width: 250px;
  }

  /* Auth Buttons */
  .account-drawer__actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 24px;
  }
  .account-drawer__signin-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 14px 24px;
    background: #222;
    color: #fff;
    border: none;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.25s, transform 0.15s;
    border-radius: 0;
  }
  .account-drawer__signin-btn:hover {
    background: #000;
    transform: translateY(-1px);
  }
  .account-drawer__register-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 14px 24px;
    background: transparent;
    color: #222;
    border: 1px solid #222;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, transform 0.15s;
    border-radius: 0;
  }
  .account-drawer__register-btn:hover {
    background: #222;
    color: #fff;
    transform: translateY(-1px);
  }

  /* Benefits */
  .account-drawer__benefits-title {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #222;
    margin: 0 0 14px;
  }
  .account-drawer__benefits-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .account-drawer__benefits-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: #555;
    line-height: 1.4;
  }
  .account-drawer__benefits-list li svg {
    flex-shrink: 0;
    color: #222;
  }

  /* Mobile responsive */
  @media screen and (max-width: 480px) {
    .account-drawer {
      max-width: 100%;
    }
  }
</style>
