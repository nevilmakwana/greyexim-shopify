<script>
  // H&M-style accordion toggle
  (function() {
    document.querySelectorAll('.koraa-hm-footer__accordion-header').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var accordion = this.closest('.koraa-hm-footer__accordion');
        var isOpen = accordion.classList.contains('is-open');
        
        // Close all others first (H&M behavior: only one open at a time)
        document.querySelectorAll('.koraa-hm-footer__accordion.is-open').forEach(function(other) {
          if (other !== accordion) {
            other.classList.remove('is-open');
            other.querySelector('.koraa-hm-footer__accordion-header').setAttribute('aria-expanded', 'false');
          }
        });
        
        // Toggle current
        if (isOpen) {
          accordion.classList.remove('is-open');
          this.setAttribute('aria-expanded', 'false');
        } else {
          accordion.classList.add('is-open');
          this.setAttribute('aria-expanded', 'true');
        }
      });
    });
  })();
</script>
