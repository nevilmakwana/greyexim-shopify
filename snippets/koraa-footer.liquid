<!-- H&M-Style Mobile Footer for Grey Exim -->
<style>
  /* ============================================
     H&M-STYLE FOOTER — KORAA CUSTOM
     ============================================ */
  .koraa-hm-footer {
    background: #fff;
    color: #222;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    padding-bottom: 100px; /* Space for mobile bottom nav */
  }

  /* Hide on desktop — only show on mobile */
  @media screen and (min-width: 750px) {
    .koraa-hm-footer {
      display: none !important;
    }
  }

  /* ---- Accordion Sections ---- */
  .koraa-hm-footer__accordions {
    border-top: 1px solid #e5e5e5;
  }

  .koraa-hm-footer__accordion {
    border-bottom: 1px solid #e5e5e5;
  }

  .koraa-hm-footer__accordion-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 18px 20px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    -webkit-tap-highlight-color: transparent;
  }

  .koraa-hm-footer__accordion-title {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #222;
    margin: 0;
    line-height: 1;
  }

  .koraa-hm-footer__accordion-icon {
    width: 16px;
    height: 16px;
    position: relative;
    flex-shrink: 0;
  }

  .koraa-hm-footer__accordion-icon::before,
  .koraa-hm-footer__accordion-icon::after {
    content: '';
    position: absolute;
    background: #222;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Horizontal line */
  .koraa-hm-footer__accordion-icon::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 1.5px;
    transform: translateY(-50%);
  }

  /* Vertical line (rotates to 0 when open) */
  .koraa-hm-footer__accordion-icon::after {
    top: 0;
    left: 50%;
    width: 1.5px;
    height: 100%;
    transform: translateX(-50%);
  }

  .koraa-hm-footer__accordion.is-open .koraa-hm-footer__accordion-icon::after {
    transform: translateX(-50%) rotate(90deg);
  }

  .koraa-hm-footer__accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .koraa-hm-footer__accordion.is-open .koraa-hm-footer__accordion-content {
    max-height: 500px;
  }

  .koraa-hm-footer__accordion-links {
    list-style: none;
    margin: 0;
    padding: 0 20px 18px 20px;
  }

  .koraa-hm-footer__accordion-links li {
    margin-bottom: 14px;
  }

  .koraa-hm-footer__accordion-links li:last-child {
    margin-bottom: 0;
  }

  .koraa-hm-footer__accordion-links a {
    color: #222;
    text-decoration: none;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.3px;
    line-height: 1.4;
    transition: opacity 0.2s ease;
  }

  .koraa-hm-footer__accordion-links a:active {
    opacity: 0.5;
  }

  /* ---- Brand / Logo Section ---- */
  .koraa-hm-footer__brand {
    padding: 40px 20px 0;
  }

  .koraa-hm-footer__logo {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: 1px;
    color: #222;
    text-transform: uppercase;
    line-height: 1;
  }

  /* ---- Region ---- */
  .koraa-hm-footer__region {
    padding: 24px 20px 0;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .koraa-hm-footer__region-text {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: #222;
  }

  /* ---- Social Icons ---- */
  .koraa-hm-footer__social {
    padding: 32px 20px 0;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .koraa-hm-footer__social a {
    color: #222;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    transition: opacity 0.2s ease;
  }

  .koraa-hm-footer__social a:active {
    opacity: 0.5;
  }

  .koraa-hm-footer__social svg {
    width: 22px;
    height: 22px;
  }

  /* ---- Copyright ---- */
  .koraa-hm-footer__copyright {
    padding: 36px 20px 0;
  }

  .koraa-hm-footer__copyright p {
    font-size: 11px;
    color: #666;
    line-height: 1.6;
    margin: 0;
  }

  /* ---- Payments ---- */
  .koraa-hm-footer__payments {
    padding: 40px 20px 20px;
  }

  .koraa-hm-footer__payments-title {
    font-size: 14px;
    font-weight: 700;
    color: #222;
    margin: 0 0 16px 0;
  }

  .koraa-hm-footer__payments-icons {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .koraa-hm-footer__payments-icons svg,
  .koraa-hm-footer__payments-icons img {
    height: 24px;
    width: auto;
  }

  .koraa-hm-footer__payment-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 32px;
    padding: 4px 6px;
    background: #f8f8f8;
    border-radius: 4px;
    border: 1px solid #eee;
  }
</style>

